; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SMWPP"
config/version="0.1_Concept"
run/main_scene="uid://0nluikbgcxd1"
config/features=PackedStringArray("4.7", "C#", "Mobile")
config/icon="uid://clp0hqsfhmk4y"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/mode=3
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="Super Engine"

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Assets/Dialogue/": "blue",
"res://Assets/Game Log/": "gray",
"res://Assets/Misc/": "gray",
"res://Assets/Scenes/": "purple",
"res://Assets/Scripts/": "red",
"res://Assets/Sounds/": "pink",
"res://Assets/Sprites/": "green",
"res://addons/": "gray",
"res://android/": "gray"
}

